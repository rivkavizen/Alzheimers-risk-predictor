# Supabase (required for saving patients, assessments, chat history)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Model paths (relative to project root — same values on Railway)
MODEL_PATH=ml/model_artifacts/xgb_model.pkl
FEATURE_NAMES_PATH=ml/model_artifacts/feature_names.json

# Railway: add SUPABASE_URL, SUPABASE_KEY, MODEL_PATH, FEATURE_NAMES_PATH as project Variables.
# Do NOT add CLAUDE_API_KEY — visitors provide their own key in the browser.

# Claude API key is entered by each visitor in the browser Settings page.
# Do NOT put CLAUDE_API_KEY here.
